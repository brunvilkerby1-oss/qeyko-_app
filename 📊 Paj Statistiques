<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Statistiques - Qeyko Mining</title>
    <style>
        :root { --primary: #c4ff00; --bg: #1a1d26; --card: #242936; --border: #3d4452; }
        body { background-color: var(--bg); color: white; font-family: sans-serif; padding: 15px; margin: 0; }
        
        .header { display: flex; align-items: center; margin-bottom: 25px; padding-top: 10px; }
        .back-btn { font-size: 28px; text-decoration: none; color: white; margin-right: 80px; }
        .title { font-size: 18px; font-weight: bold; }

        .stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-bottom: 25px; }
        .stat-card { background: var(--card); padding: 20px; border-radius: 15px; border: 1px solid var(--border); text-align: center; }
        .stat-label { font-size: 11px; color: #8a94ad; text-transform: uppercase; margin-bottom: 8px; display: block; }
        .stat-val { font-size: 18px; font-weight: bold; color: var(--primary); }

        .history-section { background: var(--card); border-radius: 20px; padding: 20px; border: 1px solid var(--border); }
        .history-title { font-size: 16px; font-weight: bold; margin-bottom: 15px; display: flex; justify-content: space-between; }
        
        .history-item { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #2d3340; }
        .history-item:last-child { border-bottom: none; }
        .h-info { display: flex; flex-direction: column; }
        .h-type { font-size: 14px; font-weight: bold; }
        .h-date { font-size: 11px; color: #8a94ad; margin-top: 3px; }
        .h-amount { color: var(--primary); font-weight: bold; font-size: 14px; }
    </style>
</head>
<body>

    <div class="header">
        <a href="index.html" class="back-btn">‹</a>
        <span class="title">Données & Revenus</span>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-label">Minage Total</span>
            <span class="stat-val">0.00 USDT</span>
        </div>
        <div class="stat-card">
            <span class="stat-label">Bonus Invités</span>
            <span class="stat-val">0.00 USDT</span>
        </div>
    </div>

    <div class="history-section">
        <div class="history-title">
            <span>Historique</span>
            <span style="font-size: 12px; color: var(--primary);">Tout voir</span>
        </div>

        <div style="text-align: center; padding: 40px 0; color: #4e5a78;">
            <div style="font-size: 40px; margin-bottom: 10px;">📄</div>
            <p style="font-size: 13px;">Aucune donnée disponible pour le moment</p>
        </div>
    </div>

    <p style="text-align: center; font-size: 11px; color: #4e5a78; margin-top: 30px;">
        Mise à jour en temps réel via BSC Scan
    </p>

</body>
</html>
